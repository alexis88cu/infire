eight":4914}},"width":5030,"height":4914},"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2026/01/Cameo-Beverly-Hills-LXR-Hotels-Resorts-Lobby.jpg"},"41343":{"alt_text":"DoubleTree by Hilton Makkah Aziziyah Lobby with potted green plants and a floral arrangement","media_details":{"sizes":{"full":{"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2026/01/DoubleTree-by-Hilton-Makkah-Aziziyah-Lobby.jpg","width":5457,"height":4093}},"width":5457,"height":4093},"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2026/01/DoubleTree-by-Hilton-Makkah-Aziziyah-Lobby.jpg"},"41402":{"alt_text":"DoubleTree by Hilton Bengaluru Airport - Courtyard with tables and chairs","media_details":{"sizes":{"full":{"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2026/02/DoubleTree-by-Hilton-Bengaluru-Airport-Courtyard.jpg","width":4498,"height":3000}},"width":4498,"height":3000},"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2026/02/DoubleTree-by-Hilton-Bengaluru-Airport-Courtyard.jpg"},"42131":{"alt_text":"Lobby sitting area at the Monarch San Antonio, Curio Collection by Hilton","media_details":{"sizes":{"full":{"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2026/03/The-Monarch-San-Antonio-Curio-Collection-by-Hilton-Lobby-Interior.jpg","width":3024,"height":2016}},"width":3024,"height":2016},"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2026/03/The-Monarch-San-Antonio-Curio-Collection-by-Hilton-Lobby-Interior.jpg"}}},"innerBlocks":[]}]},{"clientId":"06b8a087-7158-4dba-a68d-35b648100b5d","name":"corpnews-blocks/section","attributes":{"title":"We Are Hilton","cta":{"url":"/category/hilton-culture","text":"See All Articles","opensInNewTab":false},"hasCta":true,"meta":{"has_separator":true,"separator_color":"magenta"},"variation":"two-columns-grid","disableCta":false,"allowedBlock":"corpnews-blocks/posts"},"innerBlocks":[{"clientId":"0b66dc90-5aa7-4136-911e-ea4d2522ba15","name":"corpnews-blocks/posts","attributes":{"posts":[{"id":42119,"title":{"rendered":"Hilton Clinches Top Spot as Malaysia’s Best Workplace in Inaugural Ranking"},"excerpt":{"rendered":"KUALA LUMPUR, Malaysia – Hilton (NYSE: HLT) has been ranked the ​​Best Workplace in Malaysia™ 2026 by Great Place to Work® for the first time, earning the ​​top position in the large-sized business category.\u0026nbsp; This latest recognition builds on Hilton’s standing as the No. 1 World’s Best Workplace and the top hospitality workplace in South […]"},"type":"story","date":"2026-02-26T12:07:00","date_gmt":"2026-02-26T17:07:00","link":"https://stories.hilton.com/releases/hilton-clinches-top-spot-as-malaysias-best-workplace","featured_media":42120,"meta":[],"is_external":false,"primary_term":93},{"id":39907,"title":{"rendered":"Hilton Team Members Log Nearly 1.5 Million Volunteer Hours in 2025 "},"excerpt":{"rendered":"Travel with Purpose Week,\u0026nbsp;Hilton’s\u0026nbsp;annual week to celebrate and amplify the positive impact created by Hilton team members in communities around the world, inspired every Hilton corporate office and\u0026nbsp;nearly 2,000 hotels around the world to host volunteer events,\u0026nbsp;meaningfully impacting more than 132,000 community members\u0026nbsp;and\u0026nbsp;diverting more than 206,000 pounds of waste from landfill. These efforts contributed to\u0026nbsp;nearly\u0026nbsp;1.5\u0026nbsp;million […]"},"type":"story","date":"2025-12-04T13:57:36","date_gmt":"2025-12-04T18:57:36","link":"https://stories.hilton.com/travel-with-purpose/hilton-team-members-log-nearly-1-5-million-volunteer-hours-in-2025","featured_media":39912,"meta":[],"is_external":false,"primary_term":66}],"maxNumberOfPosts":2,"variation":"two-columns-grid","postType":["post","story"],"curationType":"manual","taxonomy":"story_category","terms":{"66":{"id":66,"name":"Travel with Purpose","slug":"travel-with-purpose","link":"https://stories.hilton.com/category/travel-with-purpose","parent":0,"taxonomy":"story_category"},"93":{"id":93,"name":"Awards \u0026amp; Recognition","slug":"awards-recognition","link":"https://stories.hilton.com/category/awards-recognition","parent":0,"taxonomy":"story_category"}},"multipleTerms":true,"queryArgs":[],"numberOfPosts":6,"blockContext":[],"loadAsync":false,"meta":[],"images":{"39912":{"alt_text":"Hilton Travel with Purpose Week 2025 - Hilton Sao Paulo Morumbi - team members with brooms and trash bags outside","media_details":{"sizes":{"full":{"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2025/12/Hilton-Travel-with-Purpose-Week-2025-Hilton-Sao-Paulo-Morumbi.jpg","width":1536,"height":1024}},"width":1536,"height":1024},"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2025/12/Hilton-Travel-with-Purpose-Week-2025-Hilton-Sao-Paulo-Morumbi.jpg"},"42120":{"alt_text":"Hilton Kuala Lumpur - Photo of Hilton Team celebrating Malaysia Best Workplace win","media_details":{"sizes":{"full":{"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2026/02/Hilton-Kuala-Lumpur.jpg","width":2048,"height":1536}},"width":2048,"height":1536},"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2026/02/Hilton-Kuala-Lumpur.jpg"}}},"innerBlocks":[]}]},{"clientId":"0ae54396-a039-4cfc-8f7e-5316c3d8df42","name":"corpnews-blocks/section","attributes":{"title":"Featured Video","cta":{"url":"/videos","text":"See All Videos","opensInNewTab":false},"hasCta":true,"meta":{"has_separator":true,"separator_color":"magenta"},"variation":"featured-section","disableCta":false,"allowedBlock":"corpnews-blocks/posts"},"innerBlocks":[{"clientId":"7f18a034-5647-42cf-a590-857e218d16f4","name":"corpnews-blocks/posts","attributes":{"posts":[{"id":38159,"title":{"rendered":"Hilton’s 2026 Trends Report"},"excerpt":{"rendered":"In the year ahead, travelers are redefining the journey and choosing trips that begin with purpose, not just a place. According to Hilton’s newly released 2026 Trends Report, The Whycation: Travel’s New Starting Point, the question isn’t “Where are we going?” it’s “Why are we going?” Read Hilton’s 2026 Trends Report at stories.hilton.com/2026trends."},"type":"videos","date":"2025-10-08T12:23:11","date_gmt":"2025-10-08T16:23:11","link":"https://stories.hilton.com/videos/2026-trends-video","featured_media":38160,"meta":[],"is_external":false,"primary_term":303}],"postType":["post","story","videos"],"maxNumberOfPosts":1,"variation":"featured-section","curationType":"manual","taxonomy":"story_category","terms":{"303":{"id":303,"name":"2026 Trends Report","slug":"2026-trends","link":"https://stories.hilton.com/videos/collection/2026-trends","parent":0,"taxonomy":"collection"}},"multipleTerms":true,"queryArgs":[],"numberOfPosts":6,"blockContext":[],"loadAsync":false,"meta":[],"images":{"38160":{"alt_text":"Hilton's 2026 Trends Report - AutoCamp, people by the pool","media_details":{"sizes":{"full":{"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2025/10/Video-Summary-Hiltons-2026-Trends-Report-AutoCamp.jpeg","width":9421,"height":7065}},"width":9421,"height":7065},"source_url":"https://stories-editor.hilton.com/wp-content/uploads/2025/10/Video-Summary-Hiltons-2026-Trends-Report-AutoCamp.jpeg"}}},"innerBlocks":[]}]},{"clientId":"32f600a3-7770-4ac7-84ec-7d168cd6d7ec","name":"corpnews-blocks/section","attributes":{"title":"Corporate News","disableCta":true,"meta":{"has_separator":false,"separator_color":"gradient"},"variation":"corporate-news","cta":{"url":"","text":"See all","opensInNewTab":false},"hasCta":false,"allowedBlock":"corpnews-blocks/posts"},"innerBlocks":[{"clientId":"c38b14be-394f-4069-a4b5-4aa2fd2d5531","name":"corpnews-blocks/posts","attributes":{"posts":[{"id":41673,"title":{"rendered":"Hilton Reports Fourth Quarter and Full Year Results"},"excerpt":{"rendered":"MCLEAN, VA \u0026#8211; Hilton Worldwide Holdings Inc. (\u0026#8220;Hilton,\u0026#8221; \u0026#8220;the Company,\u0026#8221; \u0026#8220;we,\u0026#8221; \u0026#8220;us\u0026#8221; or \u0026#8220;our\u0026#8221;) (NYSE: HLT) today reported its fourth quarter and full year 2025 results. Highlights include: Click here to view the full report."},"type":"story","date":"2026-02-11T06:01:40","date_gmt":"2026-02-11T11:01:40","link":"https://stories.hilton.com/releases/hilton-reports-2025-fourth-quarter-and-full-year-results","featured_media":38471,"meta":[],"is_external":false,"primary_term":80},{"id":39907,"title":{"rendered":"Hilton Team Members Log Nearly 1.5 Million Volunteer Hours in 2025 "},"excerpt":{"rendered":"Travel with Purpose Week,\u0026nbsp;Hilton’s\u0026nbsp;annual week to celebrate and amplify the positive impact created by Hilton team members in communities around the world, inspired every Hilton corporate office and\u0026nbsp;nearly 2,000 hotels around the world to host volunteer events,\u0026nbsp;meaningfully impacting more than 132,000 community members\u0026nbsp;and\u0026nbsp;diverting more than 206,000 pounds of waste from landfill. These efforts contributed to\u0026nbsp;nearly\u0026nbsp;1.5\u0026nbsp;million […]"},"type":"story","date":"2025-12-04T13:57:36","date_gmt":"2025-12-04T18:57:36","link":"https://stories.hilton.com/travel-with-purpose/hilton-team-members-log-nearly-1-5-million-volunteer-hours-in-2025","featured_media":39912,"meta":[],"is_external":false,"primary_term":66},{"id":39210,"title":{"rendered":"Hilton Again Named No. 1 World’s Best Workplace"},"excerpt":{"rendered":"MCLEAN, Va. – Once again named the No. 1 World’s Best Workplace by Fortune and Great Place to Work, Hilton (NYSE: HLT) today is releasing findings of a newly commissioned study linking the role of employee experience to consumer purchasing decisions and service experiences."},"type":"story","date":"2025-11-13T06:45:17","date_gmt":"2025-11-13T11:45:17","link":"https://stories.hilton.com/releases/hilton-named-2025-no-1-worlds-best-workplace","featured_media":39275,"meta":[],"is_external":false,"primary_term":93}],"m