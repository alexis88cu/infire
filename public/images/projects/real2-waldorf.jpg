:"We Are Hilton","title":"We Are Hilton","url":"","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":24,"children":[{"ID":6363,"post_title":"","title":"Hilton Culture","url":"https://stories.hilton.com/category/hilton-culture","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":25,"children":[]},{"ID":275,"post_title":"Hilton Careers","title":"Hilton Careers","url":"https://jobs.hilton.com","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":26,"children":[]}]}]},{"ID":26879,"post_title":"Videos","title":"Videos","url":"https://stories.hilton.com/videos","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":27,"children":[]},{"ID":250,"post_title":"Press Center","title":"Press Center","url":"https://stories.hilton.com/releases","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":28,"children":[{"ID":277,"post_title":"Media Resources","title":"Media Resources","url":"","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":29,"children":[{"ID":11141,"post_title":"","title":"Executive Bios","url":"https://stories.hilton.com/executive-bios","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":30,"children":[]},{"ID":8903,"post_title":"","title":"Fact Sheets","url":"https://stories.hilton.com/fact-sheets","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":31,"children":[]},{"ID":9399,"post_title":"","title":"Media Assets","url":"https://stories.hilton.com/media-assets","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":32,"children":[]},{"ID":7533,"post_title":"Media Kit","title":"Media Kit","url":"https://stories.hilton.com/media-kit-hilton-corporate","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":33,"children":[]},{"ID":683,"post_title":"Press Releases","title":"Press Releases","url":"/releases/","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":34,"children":[]}]},{"ID":278,"post_title":"Contacts","title":"Contacts","url":"","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":35,"children":[{"ID":280,"post_title":"Urgent Media Requests","title":"Urgent Media Requests","url":"mailto:breakingnews@hilton.com","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":36,"children":[]},{"ID":281,"post_title":"","title":"Media Inquiries \u0026 Accommodations","url":"https://stories.hilton.com/contact","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":37,"children":[]},{"ID":285,"post_title":"Influencer/Blogger Accommodations","title":"Influencer/Blogger Accommodations","url":"https://stories.hilton.com/influencer-inquiries","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":38,"children":[]}]}]},{"ID":251,"post_title":"Corporate","title":"Corporate","url":"https://stories.hilton.com/brands/corporate","target":"","attr_title":"","description":"All Corporate News","classes":[""],"xfn":"","menu_order":39,"children":[{"ID":677,"post_title":"Hilton (NYSE: HLT)","title":"Hilton (NYSE: HLT)","url":"","target":"","attr_title":"","description":"Hilton is a leading global hospitality company with a portfolio of 26 world-class brands comprising more than 9,100 properties and over 1.3 million rooms, in 143 countries and territories.","classes":[""],"xfn":"","menu_order":40,"children":[]},{"ID":13933,"post_title":"Annual Report","title":"Annual Report","url":"https://stories.hilton.com/2024-annual-report","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":41,"children":[]},{"ID":282,"post_title":"","title":"Awards \u0026 Recognition","url":"https://stories.hilton.com/awards","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":42,"children":[]},{"ID":8539,"post_title":"","title":"Growth \u0026 Development","url":"https://stories.hilton.com/category/growth-development","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":43,"children":[]},{"ID":6368,"post_title":"","title":"Corporate News","url":"https://stories.hilton.com/category/corporate-news","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":44,"children":[]},{"ID":6369,"post_title":"","title":"Financial","url":"https://stories.hilton.com/category/financial","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":45,"children":[]},{"ID":17394,"post_title":"Travel With Purpose","title":"Travel With Purpose","url":"https://esg.hilton.com","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":46,"children":[]}]},{"ID":7510,"post_title":"Brands","title":"Brands","url":"https://stories.hilton.com/brands","target":"","attr_title":"","description":"Our Brands","classes":[""],"xfn":"","menu_order":47,"children":[{"ID":271,"post_title":"","title":"Waldorf Astoria Hotels \u0026 Resorts","url":"https://stories.hilton.com/brands/waldorf-astoria","target":"","attr_title":"","description":"Waldorf Astoria Hotels \u0026#038; Resorts is a portfolio of more than 30 iconic properties that creates a unique sense of place with a relentless commitment to personal service and culinary expertise in landmark locations around the world. Unified by their inspirational environments and True Waldorf Service, Waldorf Astoria hotels deliver graceful service from the moment a guest books through checkout. In addition to the brand’s renowned hotel offerings, Waldorf Astoria boasts a best-in-class residential portfolio that provides the comfort of a private home combined with the unsurpassed amenities and legendary service of Waldorf Astoria. Waldorf Astoria is part of Hilton, a leading global hospitality company. Experience a positive stay at Waldorf Astoria Hotels \u0026#038; Resorts by booking at waldorfastoria.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Waldorf Astoria Hotels \u0026#038; Resorts at newsroom.hilton.com/waldorfastoria, and follow the brand on Twitter, Instagram and Facebook.","classes":[""],"xfn":"","menu_order":48,"children":[]},{"ID":255,"post_title":"","title":"Conrad Hotels \u0026 Resorts","url":"https://stories.hilton.com/brands/conrad-hotels","target":"","attr_title":"","description":"Spanning five continents with more than 40 properties, Conrad Hotels \u0026#038; Resorts has created a seamless connection between contemporary design, leading innovation and curated art to inspire the entrepreneurial spirit of the globally connected traveler. Conrad is a place where guests can experience service and style on their own terms — all while connecting with local and global culture. Experience a positive stay at Conrad Hotels \u0026#038; Resorts by booking at conradhotels.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Conrad Hotels \u0026#038; Resorts at newsroom.hilton.com/conradhotels, and follow the brand on Facebook, Instagram and Twitter.","classes":[""],"xfn":"","menu_order":49,"children":[]},{"ID":265,"post_title":"","title":"LXR Hotels \u0026 Resorts","url":"https://stories.hilton.com/brands/lxr-hotels","target":"","attr_title":"","description":"LXR Hotels \u0026#038; Resorts is a collection of independent luxury properties that each represent their unique location and offer a singular travel experience native to its place, history and tradition. Found in the world’s most alluring destinations, LXR Hotels \u0026#038; Resorts connects legendary properties into an exclusive network of hotels that are set apart by an unrivaled commitment to personalized service and elegant, yet locally immersive experiences for their guests. Each of the nine hotels in the collection remains steadfastly true to its heritage and culture, providing a luxurious base of exploration for the passionate, yet discerning adventurer. LXR Hotels \u0026#038; Resorts is part of Hilton, a leading global hospitality company, and each property benefits from the strength of the Hilton enterprise and its award-winning Hilton Honors program. Experience a positive stay at LXR Hotels \u0026#038; Resorts by booking at lxrhotels.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about LXR Hotels \u0026#038; Resorts at newsroom.hilton.com/lxr.","classes":[""],"xfn":"","menu_order":50,"children":[]},{"ID":27171,"post_title":"NoMad Hotels","title":"NoMad Hotels","url":"https://stories.hilton.com/brands/nomad-hotels","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":51,"children":[]},{"ID":267,"post_title":"","title":"Signia by Hilton","url":"https://stories.hilton.com/brands/signia-by-hilton","target":"","attr_title":"","description":"Signia by Hilton is a dynamic, meetings- and events-focused brand that infuses sophisticated travel and premium experiences into every aspect of the guest experience. Each Signia by Hilton hotel will offer unparalleled meetings and events capabilities with world-class design, state-of-the-art technology and signature food and beverage offerings, all backed by the Hilton name and award-winning Hilton Honors program. Learn more about Signia by Hilton at newsroom.hilton.com/signia.","classes":[""],"xfn":"","menu_order":52,"children":[]},{"ID":254,"post_title":"","title":"Canopy by Hilton","url":"https://stories.hilton.com/brands/canopy-by-hilton","target":"","attr_title":"","description":"Canopy by Hilton, Hilton’s first lifestyle brand, is a place in the neighborhood to relax and recharge, offering simple guest-directed service, comfortable spaces and thoughtfully local choices. Each hotel is designed as a natural extension of its neighborhood and delivers a fresh approach to hospitality and the guest experience. The Canopy portfolio currently contains 35 open properties around the globe with 28 under development across 16 countries and territories. Experience a positive stay at Canopy by Hilton by booking at canopybyhilton.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Canopy by Hilton at newsroom.hilton.com/canopybyhilton, and follow the brand on Facebook, Instagram, Twitter and Pinterest.","classes":[""],"xfn":"","menu_order":53,"children":[]},{"ID":262,"post_title":"","title":"Hilton Hotels \u0026 Resorts","url":"https://stories.hilton.com/brands/hilton-hotels","target":"","attr_title":"","description":"For over a century, Hilton Hotels \u0026#038; Resorts has set the benchmark for hospitality around the world, providing new product innovations and services to meet guests’ evolving needs. With nearly 600 hotels across six continents, Hilton Hotels \u0026#038; Resorts properties are located in the world’s most sought-after destinations for guests who know that where they stay matters. Experience a positive stay at Hilton Hotels \u0026#038; Resorts by booking at hiltonhotels.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Hilton Hotels \u0026#038; Resorts at newsroom.hilton.com/hhr, and follow the brand on Facebook, Twitter and Instagram.","classes":[""],"xfn":"","menu_order":54,"children":[]},{"ID":256,"post_title":"","title":"Curio Collection by Hilton","url":"https://stories.hilton.com/brands/curio-collection","target":"","attr_title":"","description":"Curio Collection by Hilton is a global portfolio of more than 115 one-of-a-kind hotels and resorts in nearly 30 countries and territories. Curio Collection properties offer guests authentic, curated experiences through distinctly local offerings and elevated amenities, while providing the benefits of Hilton and its award-winning guest loyalty program Hilton Honors. Experience a positive stay at Curio Collection by Hilton by booking at curiocollection.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Curio Collection by Hilton at newsroom.hilton.com/curio, and follow the brand on Facebook, Instagram and Twitter.","classes":[""],"xfn":"","menu_order":55,"children":[]},{"ID":27172,"post_title":"Graduate by Hilton","title":"Graduate by Hilton","url":"https://stories.hilton.com/brands/graduate-by-hilton","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":56,"children":[]},{"ID":257,"post_title":"","title":"DoubleTree by Hilton","url":"https://stories.hilton.com/brands/doubletree-by-hilton","target":"","attr_title":"","description":"DoubleTree by Hilton is a fast-growing, global portfolio of 635 hotels with more than 144,000 rooms across 50 countries and territories. For more than 50 years, DoubleTree by Hilton has continued to be a symbol of comfort for business and leisure travelers around the world, from welcoming guests with its signature warm DoubleTree chocolate chip cookie, to serving the local community. DoubleTree by Hilton offers contemporary accommodations and amenities, including unique food and beverage experiences, state-of-the-art fitness offerings and meetings and events spaces. Experience a positive stay at DoubleTree by Hilton by booking at doubletree.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about DoubleTree by Hilton at newsroom.hilton.com/doubletree, and follow the brand on Facebook, Twitter and Instagram.","classes":[""],"xfn":"","menu_order":57,"children":[]},{"ID":268,"post_title":"","title":"Tapestry Collection by Hilton","url":"https://stories.hilton.com/brands/tapestry-collection","target":"","attr_title":"","description":"Tapestry Collection by Hilton is a portfolio of more than 70 original hotels that offers guests unique style and vibrant personality, and encourages guests to explore the local destination. With plans for global expansion, every Tapestry Collection property is united by the reliability that comes with the Hilton name, in addition to the benefits of the award-winning Hilton Honors program. Experience a positive stay at Tapestry Collection by Hilton by booking at tapestrycollectionbyhilton.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Tapestry Collection by Hilton at newsroom.hilton.com/tapestry, and follow the brand on Facebook, Instagram and Twitter.","classes":[""],"xfn":"","menu_order":58,"children":[]},{"ID":37817,"post_title":"Outset Collection by Hilton","title":"Outset Collection by Hilton","url":"https://stories.hilton.com/releases/launch-of-outset-collection-by-hilton","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":59,"children":[]},{"ID":258,"post_title":"","title":"Embassy Suites by Hilton","url":"https://stories.hilton.com/brands/embassy-suites","target":"","attr_title":"","description":"Embassy Suites by Hilton, one of Hilton’s 18 market-leading brands, is dedicated to delivering what matters most to travelers. The full service, upscale brand offers both leisure and business travelers an approachable, best-in-class experience with two-room suites, free made-to-order breakfast, inviting open atriums, 24-hour fitness centers and a complimentary evening reception. Embassy Suites by Hilton offers nearly 260 open hotels with 41 properties in development. Experience a positive stay at Embassy Suites by Hilton by booking at embassysuites.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Embassy Suites by Hilton at newsroom.hilton.com/embassysuites, and follow the brand on Facebook, Twitter and Instagram.","classes":[""],"xfn":"","menu_order":60,"children":[]},{"ID":269,"post_title":"","title":"Tempo by Hilton","url":"https://stories.hilton.com/brands/tempo-by-hilton","target":"","attr_title":"","description":"Tempo by Hilton is a stylish and contemporary lifestyle hotel brand with more than 10 properties under development. Pioneering a new hospitality category, Tempo by Hilton is dedicated to exceeding the expectations of the ambitious, modern traveler and offering accommodations thoughtfully designed to help guests relax and recharge, including an open lobby concept with dedicated spaces to relax, work and dine, as well as premium culinary options, such as the brand’s signature coffee fuel bar, a casual breakfast cafe and an inviting bar experience. Created to serve a rising class of highly discerning guests committed to personal growth and development, Tempo by Hilton amenities include well-being offerings, state-of-the-art fitness facilities and programs, flexible meeting and working spaces and more. Learn more about Tempo by Hilton at newsroom.hilton.com/tempo.","classes":[""],"xfn":"","menu_order":61,"children":[]},{"ID":266,"post_title":"","title":"Motto by Hilton","url":"https://stories.hilton.com/brands/motto-by-hilton","target":"","attr_title":"","description":"Motto by Hilton is an urban, lifestyle hotel brand with 15 properties under development in prime locations globally. Motto by Hilton caters to travelers looking for value and one-of-a-kind experiences by bringing together the best elements of a lifestyle hotel – centrally located urban locations, modern design, the best of the neighborhood food and beverage and a local vibe. At its core, Motto delivers a flexible and innovative hospitality experience through elements like first-of-its-kind connecting rooms for group travel, vibrant communal spaces with access to check-in and a coffee house and bar for work and social use by guests and locals alike. Motto is part of the award-winning Hilton Honors guest loyalty program. Learn more about Motto by Hilton at newsroom.hilton.com/motto, and follow the brand on Facebook and Instagram.","classes":[""],"xfn":"","menu_order":62,"children":[]},{"ID":260,"post_title":"","title":"Hilton Garden Inn","url":"https://stories.hilton.com/brands/hilton-garden-inn","target":"","attr_title":"","description":"The award-winning Hilton Garden Inn brand provides business and leisure guests upscale, affordable accommodations and modern amenities for an experience that is simply on another level. The Hilton Garden Inn Promise affirms the brand’s goal to make each guest’s stay better and brighter. Guaranteed. With 940 hotels in 55 countries and territories around the world, the brand ensures today’s busy travelers have a bright and satisfying experience, starting with the first hello. Experience a positive stay at Hilton Garden Inn by booking at hgi.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Hilton Garden Inn at newsroom.hilton.com/hgi, and follow the brand on Facebook, Instagram and Twitter.","classes":[""],"xfn":"","menu_order":63,"children":[]},{"ID":259,"post_title":"","title":"Hampton by Hilton","url":"https://stories.hilton.com/brands/hampton-by-hilton","target":"","attr_title":"","description":"As the No. 1 ranked lodging franchise for the last 13 years by Entrepreneur®, Hampton by Hilton — including Hampton Inn by Hilton and Hampton Inn \u0026#038; Suites by Hilton — serves quality-driven and value-conscious travelers at 2,765 properties in 33 countries and territories around the globe. The brand continues to lead its segment by providing guests with high quality, thoughtfully designed accommodations and amenities, such as modern and spacious rooms, complimentary Wi-Fi and free hot breakfast. Hampton by Hilton is committed to delivering an exceptionally friendly and authentic service all backed by the 100% Hampton Guarantee™. Experience a positive stay at Hampton by Hilton by booking at hampton.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Hampton by Hilton at newsroom.hilton.com/hampton, and follow the brand on Facebook, Instagram and Twitter.","classes":[""],"xfn":"","menu_order":64,"children":[]},{"ID":270,"post_title":"","title":"Tru by Hilton","url":"https://stories.hilton.com/brands/tru-by-hilton","target":"","attr_title":"","description":"Tru by Hilton is a game-changing hotel brand with more than 210 open locations across North America, providing guests with a consistent, fun experience at an affordable price. Spirited, simplified and grounded in value, Tru by Hilton is designed for cross-generational appeal. Efficiently designed modern guestrooms feature rolling desks, oversized windows for natural light and bright, spacious bathrooms. Guests can enjoy complimentary hot breakfast and free Wi-Fi. Premium snacks, light meal options and single-serve wine and beer are available for purchase at the 24/7 Eat. \u0026#038; Sip. market. Experience a positive stay at Tru by Hilton by booking at trubyhilton.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Tru by Hilton at newsroom.hilton.com/trubyhilton, and follow the brand on Facebook, Instagram and Twitter.","classes":[""],"xfn":"","menu_order":65,"children":[]},{"ID":27292,"post_title":"","title":"Spark by Hilton","url":"https://stories.hilton.com/brands/spark-by-hilton","target":"","attr_title":"","description":"Spark by Hilton is a premium economy hotel brand at the intersection of value and consistency. Spark by Hilton provides a reliable and comfortable stay with friendly service for every guest, all at an accessible price. Spark by Hilton hotels provide a welcoming sense of arrival with colorful accent walls and inspiring artwork. The public spaces provide multi-functional seating, from communal tables to rocking chairs, and guest rooms are comfortable and relaxing with simple, streamlined furniture. In the morning, travelers can enjoy a complimentary signature bagel bar and premium coffee. Learn more about Spark by Hilton at stories.hilton.com/spark.","classes":[""],"xfn":"","menu_order":66,"children":[]},{"ID":264,"post_title":"","title":"Homewood Suites by Hilton","url":"https://stories.hilton.com/brands/homewood-suites","target":"","attr_title":"","description":"Homewood Suites by Hilton, Hilton’s upscale, award-winning, all-suite, extended-stay hotel brand, has more than 525 pet-friendly locations across the U.S., Mexico, Canada and the Caribbean, with more than 105 properties in the pipeline. Homewood Suites by Hilton offers inviting, generous-sized suites featuring separate living and sleeping areas, and fully equipped kitchens with full-size refrigerators for guests seeking home-like accommodations when traveling for extended or quick overnight stays. Additional value-driven amenities include complimentary Wi-Fi and free hot breakfast. Homewood Suites by Hilton is focused on guest satisfaction and stands behind each stay with its 100% Suite Assurance® guarantee. Experience a positive stay at Homewood Suites by Hilton by booking at homewoodsuites.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Homewood Suites by Hilton at newsroom.hilton.com/homewoodsuites, and follow the brand on Facebook, Twitter and Instagram.","classes":[""],"xfn":"","menu_order":67,"children":[]},{"ID":263,"post_title":"","title":"Home2 Suites by Hilton","url":"https://stories.hilton.com/brands/home2-suites","target":"","attr_title":"","description":"Home2 Suites by Hilton, one of the fastest growing brands in Hilton’s history, is a mid-tier, all-suite, award-winning extended-stay hotel concept designed to offer stylish accommodations with flexible guest room configurations and inspired amenities for cost-conscious guests and their pets. With a commitment to environmentally friendly products and hotel operations, Home2 Suites by Hilton offers complimentary hot breakfast, innovative and customizable guestroom designs, laundry and fitness areas, free Wi-Fi, multiple outdoor spaces, 24-hour business centers, expansive community spaces and pet-friendly environments. Home2 Suites by Hilton has more than 520 open hotels with more than 520 in development. Experience a positive stay at Home2 Suites by Hilton by booking at home2suites.com or through the industry-leading Hilton Honors app. Hilton Honors members who book directly through preferred Hilton channels have access to instant benefits. Learn more about Home2 Suites by Hilton at newsroom.hilton.com/home2suites, and follow the brand on Facebook, Twitter and Instagram.","classes":[""],"xfn":"","menu_order":68,"children":[]},{"ID":18299,"post_title":"LivSmart Studios by Hilton","title":"LivSmart Studios by Hilton","url":"https://stories.hilton.com/brands/livsmart-studios-by-hilton","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":69,"children":[]},{"ID":40996,"post_title":"Apartment Collection by Hilton","title":"Apartment Collection by Hilton","url":"https://stories.hilton.com/releases/hilton-introduces-apartment-collection-by-hilton","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":70,"children":[]},{"ID":679,"post_title":"Hilton Grand Vacations","title":"Hilton Grand Vacations","url":"https://www.hiltongrandvacations.com/news/","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":71,"children":[]},{"ID":261,"post_title":"","title":"Hilton Honors","url":"https://stories.hilton.com/brands/hilton-honors","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":72,"children":[]}]}],"footer-1":[{"ID":81,"post_title":"Hilton.com","title":"Hilton.com","url":"https://www.hilton.com/en/","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":1,"children":[]},{"ID":86,"post_title":"About Hilton","title":"About Hilton","url":"https://www.hilton.com/en/corporate/","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":2,"children":[]},{"ID":83,"post_title":"Development","title":"Development","url":"https://www.hilton.com/en/corporate/development/","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":3,"children":[]},{"ID":85,"post_title":"Investors","title":"Investors","url":"https://ir.hilton.com/","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":4,"children":[]},{"ID":84,"post_title":"Corporate Responsibility","title":"Corporate Responsibility","url":"https://travelwithpurpose.hilton.com/","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":5,"children":[]},{"ID":82,"post_title":"Careers","title":"Careers","url":"https://jobs.hilton.com/us/en","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":6,"children":[]}],"copyright":[{"ID":87,"post_title":"Global Privacy Statement","title":"Global Privacy Statement","url":"https://www.hilton.com/en/p/global-privacy-statement/","