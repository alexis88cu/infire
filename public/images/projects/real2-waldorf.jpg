 Travelers","url":"https://stories.hilton.com/2025trends/luxury-travelers","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":11,"children":[]}]},{"ID":29038,"post_title":"Trending Travel topics","title":"Trending Travel topics","url":"#","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":12,"children":[{"ID":29039,"post_title":"Vacationing vs. Traveling","title":"Vacationing vs. Traveling","url":"https://stories.hilton.com/2025trends/vacationing-vs-traveling","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":13,"children":[]},{"ID":29040,"post_title":"Points vs. Money","title":"Points vs. Money","url":"https://stories.hilton.com/2025trends/points-vs-money","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":14,"children":[]},{"ID":29041,"post_title":"High-Tech Travel Meets Digital Detox","title":"High-Tech Travel Meets Digital Detox","url":"https://stories.hilton.com/2025trends/high-tech-travel-meets-digital-detox","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":15,"children":[]}]},{"ID":32467,"post_title":"Meetings Maximizer","title":"Meetings Maximizer","url":"https://stories.hilton.com/2025eventtrends","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":16,"children":[]}],"auxiliary":[{"ID":40174,"post_title":"Hotels \u0026 Resorts","title":"Hotels \u0026 Resorts","url":"#","target":"","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":1,"children":[{"ID":40173,"post_title":"Locations","title":"Locations","url":"https://www.hilton.com/en/locations/","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":2,"children":[]},{"ID":40175,"post_title":"Brands","title":"Brands","url":"https://www.hilton.com/en/brands/","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":3,"children":[]},{"ID":40176,