xt":"View all articles","opensInNewTab":false},"identifier":"tab-6","hasCta":true,"align":"full"},"innerBlocks":[{"clientId":"7db9194e-5880-45d9-bd86-b104f3c4513d","name":"corpnews-blocks/posts","attributes":{"posts":[{"id":41412,"title":{"rendered":"What\u0026#8217;s New At Hilton in 2026"},"excerpt":{"rendered":""},"type":"story","date":"2026-02-04T12:58:35","date_gmt":"2026-02-04T17:58:35","link":"https://stories.hilton.com/whats-new-at-hilton-in-2026","featured_media":39458,"meta":[],"is_external":true,"primary_term":110},{"id":42107,"title":{"rendered":"Celebrate Cherry Blossom Season with These Hotel Offerings from Washington, D.C. to Washington State"},"excerpt":{"rendered":"Each spring, Cherry Blossoms transform Washington, D.C. into a unique landmark as they bloom and paint the city in different shades of pink and white. This natural spectacle is a gift from the Mayor of Tokyo, dating back to 1912, and it marks the beginning of the highly anticipated National Cherry Blossom Festival. This year, […]"},"type":"story","date":"2026-03-02T11:03:09","date_gmt":"2026-03-02T16:03:09","link":"https://stories.hilton.com/destination-spotlight/celebrate-cherry-blossom-season-with-these-hotel-offerings-from-washington-d-c-to-washington-state","featured_media":42111,"meta":[],"is_external":false,"primary_term":62},{"id":42100,"title":{"rendered":"Hilton to Introduce Iconic Luxury Brand Waldorf Astoria Hotels \u0026#038; Resorts to Goa"},"excerpt":{"rendered":"GOA, India – Hilton (NYSE: HLT) today announced the signing of Waldorf Astoria Goa, marking the debut of one of the world’s most iconic luxury brands to India’s storied western shoreline. The new hotel will be Hilton’s third Waldorf Astoria in India, following the signings of Waldorf Astoria Jaipur and Waldorf Astoria New Delhi, and underscores the continued expansion of Hilton’s […]"},"type":"story","date":"2026-02-26T09:00:00","date_gmt":"2026-02-26T14:00:00","link":"https://stories.hilton.com/releases/hilton-to-introduce-iconic-luxury-brand-waldorf-astoria-hotels-resorts-to-goa","featured_media":42101,"meta":[],"is_external":false,"primary_term":110},{"id":41427,"title":{"rendered":"Hilton Global Foundation Commits $5.4M to 18 Organizations Creating Pathways to Opportunity and Building Resilience in Communities Around the Globe"},"excerpt":{"rendered":"MCLEAN, Va. — The Hilton Global Foundation (HGF), the global philanthropic arm of Hilton, a global leader in hospitality, announced today it has invested $5.4 million in 18 nonprofit organizations across the globe working to expand career opportunity, advance community resilience and make the world better to travel. These grants represent HGF’s largest annual investment […]"},"type":"story","date":"2026-02-10T09:02:18","date_gmt":"2026-02-10T14:02:18","link":"https://stories.hilton.com/releases/hilton-global-foundation-commits-5-4m-to-18-organizations-around-the-globe","featured_media":41428,"meta":[],"is_external":false,"primary_term":66},{"id":42074,"title":{"rendered":"Hilton Debuts Its First Onsen Resort in South East Asia with the Opening of Hilton Quang Hanh Onsen Resort in Northern Vietnam"},"excerpt":{"rendered":"QUANG NINH, Vietnam – Hilton (NYSE: HLT) today announced the opening of Hilton Quang Hanh Onsen Resort, a retreat in the Quang Hanh valley in Cam Pha, Quang Ninh. Rooted in the destination’s natural hot mineral springs, the resort invites guests to experience its onsen-inspired immersions, paired with the warm, exceptional hospitality Hilton is known […]"},"type":"story","date":"2026-02-23T09:00:00","date_gmt":"2026-02-23T14:00:00","link":"https://stories.hilton.com/releases/hilton-quang-hanh-onsen-resort-now-open-in-northern-vietnam","featured_media":42075,"meta":[],"is_external":false,"primary_term":110},{"id":42020,"title":{"rendered":"Baldi, A Tuscan Steakhouse Born from the Baldi Family’s Culinary Legacy, Now Open at Waldorf Astoria Beverly Hills"},"excerpt":{"rendered":"LOS ANGELES – Simplicity is at the heart of Beverly Hills’ newest extension of the family dinner table at Baldi, a Tuscan steakhouse helmed by Chef Edoardo “Edo” Baldi, opening its doors on February 18. Situated within the iconic Waldorf Astoria Beverly Hills, the restaurant serves as a reimagination of the American steakhouse through a […]"},"type":"story","date":"2026-02-17T12:00:00","date_gmt":"2026-02-17T17:00:00","link":"https://stories.hilton.com/releases/baldi-a-tuscan-steakhouse-now-open-at-waldorf-astoria-beverly-hills","featured_media":42028,"meta":[],"is_external":false,"primary_term":47},{"id":26432,"title":{"rendered":"Hilton Expands Presence in North Queensland with the Signing of Hilton Garden Inn Townsville"},"excerpt":{"rendered":"SYDNEY and MCLEAN, VA – Hilton today announced the signing of Hilton Garden Inn Townsville, adding to Hilton Garden Inn’s fast-growing portfolio of 91 hotels operating across Asia Pacific. Under a management agreement with HHNQ Pty Ltd, Hilton will manage the 190-room hotel located in the beautiful coastal city of Townsville in northern Queensland.\u0026nbsp; Surrounded by […]"},"type":"story","date":"2024-05-01T08:00:00","date_gmt":"2024-05-01T12:00:00","link":"https://stories.hilton.com/releases/hilton-expands-presence-in-north-queensland-with-the-signing-of-hilton-garden-inn-townsville","featured_media":26433,"meta":[],"is_external":false,"primary_term":79}],"numberOfPosts":7,"maxNumberOfPosts":7,"postType":["post","story"],"curationType":"manual","taxonomy":"story_category","terms":{"47":{"id":47,"name":"Food \u0026amp; Beverage","slug":"food-beverage","link":"https://stories.hilton.com/category/food-beverage","parent":0,"taxonomy":"story_category"},"62":{"id":62,"name":"Destination Spotlight","slug":"destination-spotlight","link":"https://stories.hilton.com/category/destination-spotlight","parent":0,"taxonomy":"story_category"},"66":{"id":66,"name":"Travel with Purpose","slug":"travel-with-purpose","link":"https://stories.hilton.com/category/travel-w