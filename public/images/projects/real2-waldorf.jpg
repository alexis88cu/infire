,"description":"","classes":[""],"xfn":"","menu_order":22,"children":[]}]}],"auxiliary-footer":[{"ID":40195,"post_title":"Credit Cards","title":"Credit Cards","url":"https://www.hilton.com/en/hilton-honors/credit-cards/","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":1,"children":[]},{"ID":40196,"post_title":"Hilton Grand Vacations","title":"Hilton Grand Vacations","url":"https://www.hiltongrandvacations.com/en/discover-hilton-grand-vacations/nav-bar-hilton","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":2,"children":[]},{"ID":40197,"post_title":"Hilton for Business","title":"Hilton for Business","url":"https://www.hilton.com/en/p/hilton-for-business/","target":"_blank","attr_title":"","description":"","classes":[""],"xfn":"","menu_order":3,"children":[]}]},"meta":{"epas":[]}},"language":null,"__N_SSP":true},"page":"/","query":{},"buildId":"qDfsegYZqpDEFciuwMmE7","assetPrefix":"https://stories.hilton.com","runtimeConfig":{"API_ENDPOINT":"https://stories-editor.hilton.com/wp-json/corpnews/v1","FE_URL":"https://stories.hilton.com/","BASE_PATH":"","HOME_PAGE_TITLE":"Latest News","NODE_OPTIONS":"--insecure-http-parser","ANALYTICS_ENVIRONMENT":"prod","RECAPTCHA_SITE_KEY":"6Le5QEMhAAAAAIU4k_7dQ1Nwt8SjbQuPYP-ZVe21","GENERIC_TAXONOMY_ENDPOINT":"brand/","GENERIC_TAXONOMY_STORIES_TERM":"brand","ARTICLE_TYPES":["releases","stories","latest","team-member-story","rooms-with-a-view","this-week-in-hilton-history"],"GLOBAL_MEDIA_LIBRARY_SITES":["emea","apac"]},"isFallback":false,"isExperimentalCompile":false,"gssp":true,"appGip":true,"locale":"en","locales":["en","emea","apac"],"defaultLocale":"en","scriptLoader":[]}</script></body></html>